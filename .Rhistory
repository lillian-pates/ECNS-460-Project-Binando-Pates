flood_counts <- model_df |>
count(flood_flag) |>
mutate(
label  = if_else(flood_flag == 1, "Flood", "No flood"),
pct    = n / sum(n),
pct_lab = paste0(round(pct * 100, 1), "%")
)
p_balance <- flood_counts |>
ggplot(aes(x = label, y = n, fill = label)) +
geom_col(width = 0.5, show.legend = FALSE) +
geom_text(aes(label = paste0(pct_lab, "\n(n=", comma(n), ")")),
vjust = -0.3, size = 3.5) +
scale_fill_manual(values = c("Flood" = "#E24B4A", "No flood" = "#378ADD")) +
scale_y_continuous(labels = comma, expand = expansion(mult = c(0, 0.15))) +
labs(
title    = "2. Class Balance of flood_flag",
subtitle = "Severe imbalance (< 5% flood) may need SMOTE, weighting, or threshold tuning",
x        = NULL,
y        = "Observations"
) +
theme_minimal(base_size = 12) +
theme(panel.grid.major.x = element_blank())
p_balance
# Violin + boxplot overlay
p_violin <- model_df |>
mutate(flood_day = if_else(flood_flag == 1, "Flood", "No flood")) |>
ggplot(aes(x = flood_day, y = log_flow, fill = flood_day)) +
geom_violin(alpha = 0.6, trim = TRUE) +
geom_boxplot(width = 0.15, outlier.size = 0.6, alpha = 0.8) +
scale_fill_manual(values = c("Flood" = "#E24B4A", "No flood" = "#378ADD")) +
labs(
title    = "3a. log(Flow) by Flood Status",
subtitle = "Good separation = the predictor will be useful",
x        = NULL,
y        = "log1p(flow)",
fill     = NULL
) +
theme_minimal(base_size = 12) +
theme(legend.position = "none")
# Predicted flow vs observed — are they correlated?
p_pred_obs <- model_df |>
ggplot(aes(x = log_flow, y = log_pred_flow)) +
geom_point(aes(color = factor(flood_flag)), alpha = 0.3, size = 0.7) +
geom_smooth(method = "lm", color = "#185FA5", se = TRUE, linewidth = 0.8) +
scale_color_manual(values = c("0" = "gray60", "1" = "#E24B4A"),
labels = c("0" = "No flood", "1" = "Flood")) +
labs(
title    = "3b. Observed vs. Predicted Flow (log scale)",
subtitle = "Should be strongly correlated; outliers are interesting",
x        = "log1p(observed flow)",
y        = "log1p(predicted flow)",
color    = NULL
) +
theme_minimal(base_size = 12) +
theme(legend.position = "top")
p_violin | p_pred_obs
vars_for_pairs <- model_df |>
select(log_flow, log_pred_flow, flow_lag1, flow_lag7, doy, flood_flag) |>
mutate(
flood_flag    = factor(flood_flag, labels = c("No flood", "Flood")),
log_lag1      = log1p(flow_lag1),
log_lag7      = log1p(flow_lag7)
) |>
select(log_flow, log_pred_flow, log_lag1, log_lag7, doy, flood_flag)
ggpairs(
vars_for_pairs,
aes(color = flood_flag, alpha = 0.4),
upper = list(continuous = wrap("cor", size = 3)),
lower = list(continuous = wrap("points", size = 0.4)),
diag  = list(continuous = wrap("densityDiag")),
columns = 1:5    # exclude factor column from axes
) +
scale_color_manual(values = c("No flood" = "#378ADD", "Flood" = "#E24B4A")) +
scale_fill_manual( values = c("No flood" = "#378ADD", "Flood" = "#E24B4A")) +
labs(title = "4. Scatterplot Matrix of Candidate Predictors") +
theme_minimal(base_size = 10)
library(tidyverse)
library(patchwork)
library(scales)
library(corrplot)     # correlation matrix
library(GGally)       # ggpairs scatterplot matrix
library(zoo)          # acf/pacf rolling
library(tseries)      # adf test (stationarity)
library(car)          # VIF after a test lm
model_df <- flood_window |>
filter(!is.na(river_flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(river_flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(river_flow, 1),
flow_lag7     = lag(river_flow, 7),
flow_lag30    = lag(river_flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
flood_counts <- model_df |>
count(flood_flag) |>
mutate(
label  = if_else(flood_flag == 1, "Flood", "No flood"),
pct    = n / sum(n),
pct_lab = paste0(round(pct * 100, 1), "%")
)
p_balance <- flood_counts |>
ggplot(aes(x = label, y = n, fill = label)) +
geom_col(width = 0.5, show.legend = FALSE) +
geom_text(aes(label = paste0(pct_lab, "\n(n=", comma(n), ")")),
vjust = -0.3, size = 3.5) +
scale_fill_manual(values = c("Flood" = "#E24B4A", "No flood" = "#378ADD")) +
scale_y_continuous(labels = comma, expand = expansion(mult = c(0, 0.15))) +
labs(
title    = "2. Class Balance of flood_flag",
subtitle = "Severe imbalance (< 5% flood) may need SMOTE, weighting, or threshold tuning",
x        = NULL,
y        = "Observations"
) +
theme_minimal(base_size = 12) +
theme(panel.grid.major.x = element_blank())
p_balance
# Violin + boxplot overlay
p_violin <- model_df |>
mutate(flood_day = if_else(flood_flag == 1, "Flood", "No flood")) |>
ggplot(aes(x = flood_day, y = log_flow, fill = flood_day)) +
geom_violin(alpha = 0.6, trim = TRUE) +
geom_boxplot(width = 0.15, outlier.size = 0.6, alpha = 0.8) +
scale_fill_manual(values = c("Flood" = "#E24B4A", "No flood" = "#378ADD")) +
labs(
title    = "3a. log(Flow) by Flood Status",
subtitle = "Good separation = the predictor will be useful",
x        = NULL,
y        = "log1p(flow)",
fill     = NULL
) +
theme_minimal(base_size = 12) +
theme(legend.position = "none")
# Predicted flow vs observed — are they correlated?
p_pred_obs <- model_df |>
ggplot(aes(x = log_flow, y = log_pred_flow)) +
geom_point(aes(color = factor(flood_flag)), alpha = 0.3, size = 0.7) +
geom_smooth(method = "lm", color = "#185FA5", se = TRUE, linewidth = 0.8) +
scale_color_manual(values = c("0" = "gray60", "1" = "#E24B4A"),
labels = c("0" = "No flood", "1" = "Flood")) +
labs(
title    = "3b. Observed vs. Predicted Flow (log scale)",
subtitle = "Should be strongly correlated; outliers are interesting",
x        = "log1p(observed flow)",
y        = "log1p(predicted flow)",
color    = NULL
) +
theme_minimal(base_size = 12) +
theme(legend.position = "top")
p_violin | p_pred_obs
vars_for_pairs <- model_df |>
select(log_flow, log_pred_flow, flow_lag1, flow_lag7, doy, flood_flag) |>
mutate(
flood_flag    = factor(flood_flag, labels = c("No flood", "Flood")),
log_lag1      = log1p(flow_lag1),
log_lag7      = log1p(flow_lag7)
) |>
select(log_flow, log_pred_flow, log_lag1, log_lag7, doy, flood_flag)
ggpairs(
vars_for_pairs,
aes(color = flood_flag, alpha = 0.4),
upper = list(continuous = wrap("cor", size = 3)),
lower = list(continuous = wrap("points", size = 0.4)),
diag  = list(continuous = wrap("densityDiag")),
columns = 1:5    # exclude factor column from axes
) +
scale_color_manual(values = c("No flood" = "#378ADD", "Flood" = "#E24B4A")) +
scale_fill_manual( values = c("No flood" = "#378ADD", "Flood" = "#E24B4A")) +
labs(title = "4. Scatterplot Matrix of Candidate Predictors") +
theme_minimal(base_size = 10)
cor_data <- model_df |>
select(flow, pred_flow, flow_lag1, flow_lag7, flow_lag30, doy, flood_flag) |>
drop_na() |>
cor(method = "spearman")   # Spearman: robust to skew
corrplot(
cor_data,
method   = "color",
type     = "upper",
order    = "hclust",          # clusters correlated vars together
addCoef.col = "black",
number.cex  = 0.75,
tl.col   = "black",
tl.srt   = 45,
col      = colorRampPalette(c("#185FA5", "white", "#E24B4A"))(200),
title    = "5. Spearman Correlation Matrix",
mar      = c(0, 0, 2, 0)
)
test_lm <- lm(
flood_flag ~ log_flow + log_pred_flow + flow_lag1 + flow_lag7 + doy,
data = model_df
)
vif_vals <- car::vif(test_lm)
vif_df <- tibble(
predictor = names(vif_vals),
VIF       = vif_vals
)
p_vif <- vif_df |>
ggplot(aes(x = fct_reorder(predictor, VIF), y = VIF, fill = VIF > 5)) +
geom_col(width = 0.6) +
geom_hline(yintercept = 5,  linetype = "dashed", color = "#EF9F27", linewidth = 0.8) +
geom_hline(yintercept = 10, linetype = "dashed", color = "#E24B4A", linewidth = 0.8) +
annotate("text", x = 0.6, y = 5.4,  label = "VIF = 5 (caution)",  hjust = 0, size = 3, color = "#EF9F27") +
annotate("text", x = 0.6, y = 10.4, label = "VIF = 10 (problem)", hjust = 0, size = 3, color = "#E24B4A") +
scale_fill_manual(values = c("FALSE" = "#378ADD", "TRUE" = "#E24B4A")) +
coord_flip() +
labs(
title    = "6. Variance Inflation Factor (VIF)",
subtitle = "Flags which predictors are redundant",
x        = NULL,
y        = "VIF",
fill     = "VIF > 5"
) +
theme_minimal(base_size = 12) +
theme(legend.position = "none")
p_vif
flow_ts <- model_df |> pull(log_flow)
par(mfrow = c(2, 2), mar = c(4, 4, 3, 1))
acf(flow_ts,  lag.max = 60, main = "7a. ACF — log(flow)")
pacf(flow_ts, lag.max = 60, main = "7b. PACF — log(flow)")
# Also check residuals from a naive model
resid_ts <- residuals(test_lm)
acf(resid_ts,  lag.max = 60, main = "7c. ACF — OLS residuals")
pacf(resid_ts, lag.max = 60, main = "7d. PACF — OLS residuals")
par(mfrow = c(1, 1))
adf_flow <- adf.test(flow_ts, alternative = "stationary")
adf_pred <- adf.test(model_df$log_pred_flow, alternative = "stationary")
adf_results <- tibble(
Variable  = c("log_flow", "log_pred_flow"),
ADF_stat  = c(adf_flow$statistic, adf_pred$statistic),
p_value   = c(adf_flow$p.value,   adf_pred$p.value),
Stationary = p_value < 0.05
)
print(adf_results)
p_season_flow <- model_df |>
ggplot(aes(x = month, y = log_flow, fill = month)) +
geom_boxplot(alpha = 0.7, outlier.size = 0.5, show.legend = FALSE) +
scale_fill_viridis_d(option = "mako", begin = 0.2, end = 0.8) +
labs(
title    = "9a. Monthly Flow Distribution",
subtitle = "Strong seasonality = include month/doy as covariate",
x        = NULL,
y        = "log1p(flow)"
) +
theme_minimal(base_size = 12)
p_season_flood <- model_df |>
group_by(month) |>
summarise(flood_rate = mean(flood_flag), .groups = "drop") |>
ggplot(aes(x = month, y = flood_rate, group = 1)) +
geom_col(fill = "#E24B4A", alpha = 0.7, width = 0.7) +
geom_line(color = "#185FA5", linewidth = 0.8) +
geom_point(color = "#185FA5", size = 2) +
scale_y_continuous(labels = percent_format(accuracy = 0.1)) +
labs(
title    = "9b. Flood Rate by Month",
subtitle = "When are floods most likely?",
x        = NULL,
y        = "Proportion of flood days"
) +
theme_minimal(base_size = 12)
p_season_flow / p_season_flood
