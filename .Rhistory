# -- 6b. Floodplain extents by return period ----------------
# Stack all floodplain layers with labels
flood_plains <- bind_rows(
flood_plain2yr   |> mutate(return_period = "2-year"),
flood_plain5yr   |> mutate(return_period = "5-year"),
flood_plain10yr  |> mutate(return_period = "10-year"),
flood_plain25yr  |> mutate(return_period = "25-year"),
flood_plain50yr  |> mutate(return_period = "50-year"),
flood_plain100yr |> mutate(return_period = "100-year")
) |>
mutate(return_period = factor(return_period,
levels = c("2-year", "5-year", "10-year", "25-year", "50-year", "100-year")
))
map_floodplains <- tm_shape(flood_plains) +
tm_polygons(
col          = "return_period",
palette      = "Blues",
alpha        = 0.55,
border.alpha = 0.3,
title        = "Return period"
) +
tm_shape(rivers) +
tm_lines(col = "#185FA5", lwd = 1.0) +
tm_layout(
title          = "Floodplain Extents by Return Period",
title.size     = 0.95,
frame          = FALSE,
legend.outside = TRUE
) +
tm_compass(type = "arrow", position = c("left", "top"), size = 1.5) +
tm_scale_bar(position = c("left", "bottom"))
map_floodplains
pop_fp2   <- st_intersection(population, flood_plain2yr)   |> mutate(tier = "2-year")
pop_fp5   <- st_intersection(population, flood_plain5yr)   |> mutate(tier = "5-year")
pop_fp10  <- st_intersection(population, flood_plain10yr)  |> mutate(tier = "10-year")
pop_fp25  <- st_intersection(population, flood_plain25yr)  |> mutate(tier = "25-year")
pop_fp50  <- st_intersection(population, flood_plain50yr)  |> mutate(tier = "50-year")
pop_fp100 <- st_intersection(population, flood_plain100yr) |> mutate(tier = "100-year")
pop_in_plains <- bind_rows(pop_fp2, pop_fp5, pop_fp10,
pop_fp25, pop_fp50, pop_fp100) |>
mutate(tier = factor(tier,
levels = c("2-year", "5-year", "10-year", "25-year", "50-year", "100-year")
))
map_pop <- tm_shape(pop_in_plains) +
tm_polygons(
col    = "tier",
palette = "YlOrRd",
alpha  = 0.65,
title  = "Flood exposure tier"
) +
tm_shape(buildings) +
tm_dots(size = 0.05, col = "gray30", alpha = 0.4) +
tm_layout(
title          = "Population & Buildings in Flood Zones",
title.size     = 0.95,
frame          = FALSE,
legend.outside = TRUE
) +
tm_scale_bar(position = c("left", "bottom"))
map_pop
