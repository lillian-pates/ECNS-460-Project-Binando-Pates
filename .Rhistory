floods <- flood_events |>
mutate(
date = ymd(date),
flood_flag = 1 # create binary flood indicator
) |>
select(date, flood_flag, cause, flood_type) # keep only certain cols.
# join datasets
combine <- forecast_flow |>
left_join(observed_flow, by = "date") |>
left_join(floods, by = "date") |>
mutate(
flood_flag = if_else(is.na(flood_flag), 0, flood_flag)
)
# create multiple flood windows
# multi-day floods; day reported != to actual day of flood
flood_window <- combine |>
mutate(
flood_event = flood_flag,
flood_window_m2_p2 = slide_int(flood_event, max, .before = 2, .after = 2),
flood_window_m3_p3 = slide_int(flood_event, max, .before = 3, .after = 3),
flood_window_m2_p1 = slide_int(flood_event, max, .before = 2, .after = 1),
flood_window_m2_p3 = slide_int(flood_event, max, .before = 2, .after = 3)
)
# check
head(flood_window)
tail(flood_window)
summary(flood_window)
any(duplicated(flood_window$date))
colSums(is.na(flood_window))
model_df <- flood_window |>
filter(!is.na(flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(flow, 1),
flow_lag7     = lag(flow, 7),
flow_lag30    = lag(flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
model_df <- flood_window |>
filter(!is.na(river_flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(flow, 1),
flow_lag7     = lag(flow, 7),
flow_lag30    = lag(flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
model_df <- flood_window |>
filter(!is.na(river_flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(river_flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(river_flow, 1),
flow_lag7     = lag(river_flow, 7),
flow_lag30    = lag(river_flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
p_raw <- model_df |>
ggplot(aes(x = flow)) +
geom_histogram(fill = "#378ADD", color = "white", bins = 60) +
scale_x_continuous(labels = comma) +
labs(title = "Flow — raw", x = "Flow (m³/s)", y = "Count") +
theme_minimal(base_size = 11)
p_log <- model_df |>
ggplot(aes(x = log_flow)) +
geom_histogram(fill = "#185FA5", color = "white", bins = 60) +
labs(title = "Flow — log1p transformed", x = "log1p(flow)", y = "Count") +
theme_minimal(base_size = 11)
p_qq_raw <- model_df |>
ggplot(aes(sample = flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#378ADD") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: raw flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
p_qq_log <- model_df |>
ggplot(aes(sample = log_flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#185FA5") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: log1p flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
(p_raw | p_log) / (p_qq_raw | p_qq_log) +
plot_annotation(
title    = "1. Outcome Distribution Check",
subtitle = "Compare raw vs. log — prefer the one closer to normal for linear models;\nlog doesn't matter for logistic regression but helps interpretation"
)
p_raw <- model_df |>
ggplot(aes(x = river_flow)) +
geom_histogram(fill = "#378ADD", color = "white", bins = 60) +
scale_x_continuous(labels = comma) +
labs(title = "Flow — raw", x = "Flow (m³/s)", y = "Count") +
theme_minimal(base_size = 11)
p_log <- model_df |>
ggplot(aes(x = log_flow)) +
geom_histogram(fill = "#185FA5", color = "white", bins = 60) +
labs(title = "Flow — log1p transformed", x = "log1p(flow)", y = "Count") +
theme_minimal(base_size = 11)
p_qq_raw <- model_df |>
ggplot(aes(sample = river_flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#378ADD") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: raw flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
p_qq_log <- model_df |>
ggplot(aes(sample = log_flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#185FA5") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: log1p flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
(p_raw | p_log) / (p_qq_raw | p_qq_log) +
plot_annotation(
title    = "1. Outcome Distribution Check",
subtitle = "Compare raw vs. log — prefer the one closer to normal for linear models;\nlog doesn't matter for logistic regression but helps interpretation"
)
flood_counts <- model_df |>
count(flood_flag) |>
mutate(
label  = if_else(flood_flag == 1, "Flood", "No flood"),
pct    = n / sum(n),
pct_lab = paste0(round(pct * 100, 1), "%")
)
p_balance <- flood_counts |>
ggplot(aes(x = label, y = n, fill = label)) +
geom_col(width = 0.5, show.legend = FALSE) +
geom_text(aes(label = paste0(pct_lab, "\n(n=", comma(n), ")")),
vjust = -0.3, size = 3.5) +
scale_fill_manual(values = c("Flood" = "#E24B4A", "No flood" = "#378ADD")) +
scale_y_continuous(labels = comma, expand = expansion(mult = c(0, 0.15))) +
labs(
title    = "2. Class Balance of flood_flag",
subtitle = "Severe imbalance (< 5% flood) may need SMOTE, weighting, or threshold tuning",
x        = NULL,
y        = "Observations"
) +
theme_minimal(base_size = 12) +
theme(panel.grid.major.x = element_blank())
p_balance
