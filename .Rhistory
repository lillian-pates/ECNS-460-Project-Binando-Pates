title.size     = 1,
frame          = FALSE,
bg.color       = "white",
legend.outside = TRUE
) +
tm_compass(type = "arrow", position = c("left", "top"), size = 1.5) +
tm_scale_bar(position = c("left", "bottom"))
map_hillshade
# -- 6b. Floodplain extents by return period ----------------
# Stack all floodplain layers with labels
flood_plains <- bind_rows(
flood_plain2yr   |> mutate(return_period = "2-year"),
flood_plain5yr   |> mutate(return_period = "5-year"),
flood_plain10yr  |> mutate(return_period = "10-year"),
flood_plain25yr  |> mutate(return_period = "25-year"),
flood_plain50yr  |> mutate(return_period = "50-year"),
flood_plain100yr |> mutate(return_period = "100-year")
) |>
mutate(return_period = factor(return_period,
levels = c("2-year", "5-year", "10-year", "25-year", "50-year", "100-year")
))
map_floodplains <- tm_shape(flood_plains) +
tm_polygons(
col          = "return_period",
palette      = "Blues",
alpha        = 0.55,
border.alpha = 0.3,
title        = "Return period"
) +
tm_shape(rivers) +
tm_lines(col = "#185FA5", lwd = 1.0) +
tm_layout(
title          = "Floodplain Extents by Return Period",
title.size     = 0.95,
frame          = FALSE,
legend.outside = TRUE
) +
tm_compass(type = "arrow", position = c("left", "top"), size = 1.5) +
tm_scale_bar(position = c("left", "bottom"))
map_floodplains
pop_fp2   <- st_intersection(population, flood_plain2yr)   |> mutate(tier = "2-year")
pop_fp5   <- st_intersection(population, flood_plain5yr)   |> mutate(tier = "5-year")
pop_fp10  <- st_intersection(population, flood_plain10yr)  |> mutate(tier = "10-year")
pop_fp25  <- st_intersection(population, flood_plain25yr)  |> mutate(tier = "25-year")
pop_fp50  <- st_intersection(population, flood_plain50yr)  |> mutate(tier = "50-year")
pop_fp100 <- st_intersection(population, flood_plain100yr) |> mutate(tier = "100-year")
pop_in_plains <- bind_rows(pop_fp2, pop_fp5, pop_fp10,
pop_fp25, pop_fp50, pop_fp100) |>
mutate(tier = factor(tier,
levels = c("2-year", "5-year", "10-year", "25-year", "50-year", "100-year")
))
map_pop <- tm_shape(pop_in_plains) +
tm_polygons(
col    = "tier",
palette = "YlOrRd",
alpha  = 0.65,
title  = "Flood exposure tier"
) +
tm_shape(buildings) +
tm_dots(size = 0.05, col = "gray30", alpha = 0.4) +
tm_layout(
title          = "Population & Buildings in Flood Zones",
title.size     = 0.95,
frame          = FALSE,
legend.outside = TRUE
) +
tm_scale_bar(position = c("left", "bottom"))
map_pop
# Load Packages
library(tidyverse)
library(readxl)
library(here)
library(slider)
# Load Data
observed_flow <- read_csv(here("data", "raw", "daily_hydrology_pozarica_1952_2025.csv"))
predicted_flow <- read_csv(here("data", "raw", "forecasted_flow.csv"))
flood_events <- read_xlsx(here("data", "raw", "poza_rica_floods_1971_2025_combined.xlsx"))
# Clean
# prep for dataset join
# convert str date to dttm
forecast_flow <- predicted_flow |>
rename(pred_flow = flow) |> # rename var.
mutate(
date = mdy(date)
)
floods <- flood_events |>
mutate(
date = ymd(date),
flood_flag = 1 # create binary flood indicator
) |>
select(date, flood_flag, cause, flood_type) # keep only certain cols.
# join datasets
combine <- forecast_flow |>
left_join(observed_flow, by = "date") |>
left_join(floods, by = "date") |>
mutate(
flood_flag = if_else(is.na(flood_flag), 0, flood_flag)
)
# create multiple flood windows
# multi-day floods; day reported != to actual day of flood
flood_window <- combine |>
mutate(
flood_event = flood_flag,
flood_window_m2_p2 = slide_int(flood_event, max, .before = 2, .after = 2),
flood_window_m3_p3 = slide_int(flood_event, max, .before = 3, .after = 3),
flood_window_m2_p1 = slide_int(flood_event, max, .before = 2, .after = 1),
flood_window_m2_p3 = slide_int(flood_event, max, .before = 2, .after = 3)
)
# check
head(flood_window)
tail(flood_window)
summary(flood_window)
any(duplicated(flood_window$date))
colSums(is.na(flood_window))
model_df <- flood_window |>
filter(!is.na(flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(flow, 1),
flow_lag7     = lag(flow, 7),
flow_lag30    = lag(flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
model_df <- flood_window |>
filter(!is.na(river_flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(flow, 1),
flow_lag7     = lag(flow, 7),
flow_lag30    = lag(flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
model_df <- flood_window |>
filter(!is.na(river_flow), !is.na(pred_flow)) |>
mutate(
log_flow      = log1p(river_flow),
log_pred_flow = log1p(pred_flow),
month         = month(date, label = TRUE),
year          = year(date),
doy           = yday(date),           # day of year (seasonality proxy)
flow_lag1     = lag(river_flow, 1),
flow_lag7     = lag(river_flow, 7),
flow_lag30    = lag(river_flow, 30),
pred_lag1     = lag(pred_flow, 1)
) |>
drop_na(flow_lag1, flow_lag7, flow_lag30)
p_raw <- model_df |>
ggplot(aes(x = flow)) +
geom_histogram(fill = "#378ADD", color = "white", bins = 60) +
scale_x_continuous(labels = comma) +
labs(title = "Flow — raw", x = "Flow (m³/s)", y = "Count") +
theme_minimal(base_size = 11)
p_log <- model_df |>
ggplot(aes(x = log_flow)) +
geom_histogram(fill = "#185FA5", color = "white", bins = 60) +
labs(title = "Flow — log1p transformed", x = "log1p(flow)", y = "Count") +
theme_minimal(base_size = 11)
p_qq_raw <- model_df |>
ggplot(aes(sample = flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#378ADD") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: raw flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
p_qq_log <- model_df |>
ggplot(aes(sample = log_flow)) +
stat_qq(size = 0.6, alpha = 0.4, color = "#185FA5") +
stat_qq_line(color = "#E24B4A") +
labs(title = "Q-Q: log1p flow", x = "Theoretical", y = "Sample") +
theme_minimal(base_size = 11)
(p_raw | p_log) / (p_qq_raw | p_qq_log) +
plot_annotation(
title    = "1. Outcome Distribution Check",
subtitle = "Compare raw vs. log — prefer the one closer to normal for linear models;\nlog doesn't matter for logistic regression but helps interpretation"
)
